{
  "expo": {
    "name": "Loop",
    "slug": "loop-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "loop",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.loop.mobile"
    },
    "android": {
      "package": "com.loop.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#4F6BFF"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Loop to access your photos to share content."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow Loop to access your microphone for recording reels."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e8d216a1-663e-44ea-805a-821c12f823cc"
      }
    }
  }
}
