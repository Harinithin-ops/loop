{
  "expo": {
    "name": "Loop",
    "slug": "loop-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "loop",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.loop.mobile"
    },
    "android": {
      "package": "com.loop.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F6BFF"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-image",
      "react-native-video",
      [
        "expo-image-picker",
        { "photosPermission": "Allow Loop to access your photos to share content." }
      ],
      [
        "expo-av",
        { "microphonePermission": "Allow Loop to access your microphone for recording reels." }
      ]
    ],
    "extra": {
      "router": { "origin": false }
    }
  }
}
